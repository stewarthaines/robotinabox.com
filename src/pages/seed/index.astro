<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SEED — Simple EPUB Editor</title>
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: Helvetica, Arial, sans-serif;
        background: #fff;
        color: #111;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      #content { max-width: 30em; padding: 3em 1.5em; }
      img { width: 6em; margin-bottom: 2em; }
      h1 { font-size: 2em; letter-spacing: 0.1em; margin-bottom: 0.25em; }
      .sub { font-size: 0.85em; letter-spacing: 0.15em; color: #999; text-transform: uppercase; margin-bottom: 2em; }
      p { color: #666; line-height: 1.6; margin-bottom: 2em; }
      a.back { font-size: 0.85em; color: #999; text-decoration: none; letter-spacing: 0.05em; }
      a.back:hover { color: #111; }
    </style>
  </head>
  <body>
    <div id="content">
      <img src="/img/RobotInaBox-trademark_logo.png" alt="RobotInaBox" />
      <h1>SEED</h1>
      <p class="sub">Simple EPUB Editor</p>
      <p>The app is coming soon. Replace this file with SEED.html when ready.</p>
      <a class="back" href="/">← robotinabox.com</a>
    </div>
  </body>
</html>
